# Python / test clutter
__pycache__/
*.py[cod]
.pytest_cache/

# Local build and publish output — regenerated by the release pipeline
dist/
site/
*.zip

# Local development state, notes, and scratch — not for the public repo
local/
.agents/
Cloth_NeXt_Roadmap.md

# Internal development docs stay local. Only the docs required by the release
# policy and linked from the README are tracked. tools/ and tests/ must stay
# tracked: .github/workflows/release.yml runs pytest and the tools/ validators
# directly from the repository.
docs/*
!docs/RELEASE_POLICY.md
!docs/UPDATE_CHANNELS.md
!docs/SOLVER_INSTALLATION.md
!docs/SOLVER_DISTRIBUTION.md
!docs/SOLVER_COMPATIBILITY_MANIFEST.md

# External PPF Contact Solver runtime (ST Tech / ZOZO) — never committed,
# never versioned through Git LFS. Local development copies stay ignored
# (strategy B, see docs/SOLVER_DISTRIBUTION.md and docs/RELEASE_POLICY.md).
solver/windows-x86_64/*
!solver/windows-x86_64/README.md
!solver/windows-x86_64/.gitkeep
downloads/
managed_solver/
staging/
*.partial
