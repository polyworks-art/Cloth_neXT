# Python / test clutter
__pycache__/
*.py[cod]
.pytest_cache/

# Local build and publish output — regenerated by the release pipeline
dist/
companion/dist/
companion/build/
companion/*.spec
site/
*.zip

# Local development state, notes, and scratch — not for the public repo
local/
.agents/
Cloth_NeXt_Roadmap.md

# Phase 2.7: all architecture, protocol, and policy documents are tracked in
# Git. tools/ and tests/ stay tracked as well — the CI and release workflows
# run pytest and the tools/ validators directly from the repository.

# External PPF Contact Solver runtime (ST Tech / ZOZO) — never committed,
# never versioned through Git LFS. Local development copies stay ignored
# (strategy B, see docs/SOLVER_DISTRIBUTION.md and docs/RELEASE_POLICY.md).
solver/windows-x86_64/*
!solver/windows-x86_64/README.md
!solver/windows-x86_64/.gitkeep
downloads/
managed_solver/
staging/
*.partial
